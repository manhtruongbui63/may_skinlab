APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Dedicated channel for frontend telemetry (POST /api/logs). Loki-ready JSON.
LOG_FRONTEND_LEVEL=debug
LOG_FRONTEND_DAYS=14

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=bks_db
# DB_USERNAME=root
# DB_PASSWORD=

# =============================================================================
# SPA SESSION AUTH (Sanctum, cookie-based) — READ BEFORE EDITING
# -----------------------------------------------------------------------------
# Auth = session cookie, not a bearer token. Login (web guard) only PERSISTS the
# session if Sanctum marks the request "stateful", which happens only when the
# request's Origin/Referer matches SANCTUM_STATEFUL_DOMAINS. If it doesn't match,
# login returns 200 + user but nothing is saved -> every later call is 401.
#
# The 3 settings below must agree, all pointing at the FRONTEND. Two classic
# mistakes that both look like "login works but auth is lost":
#   1) SANCTUM_STATEFUL_DOMAINS set to the API host instead of the FE host.
#   2) SESSION_SAME_SITE=none WITHOUT SESSION_SECURE_COOKIE=true  -> the browser
#      silently drops the session cookie (None requires Secure + HTTPS).
#
# FE and API on sibling subdomains of the same registrable domain (the usual
# case, e.g. app.example.com + api.example.com) are SAME-SITE -> use SameSite=lax
# (sent on cross-subdomain XHR) and share the cookie via SESSION_DOMAIN=.example.com.
# Only a truly cross-site SPA (different registrable domain) needs SameSite=none
# (and then SECURE_COOKIE=true + HTTPS on both sides).
#
# Production example (FE=app.example.com, API=api.example.com, HTTPS):
#   SESSION_DOMAIN=.example.com
#   SESSION_SAME_SITE=lax
#   SESSION_SECURE_COOKIE=true
#   SANCTUM_STATEFUL_DOMAINS=app.example.com         # <- FE host, NOT api.*
#   CORS_ALLOWED_ORIGINS=https://app.example.com     # <- FE origin, WITH scheme
#
# After changing any of these on a server: `php artisan config:clear`
# (or re-run config:cache if you cache config) AND restart php-fpm so OPcache
# drops the old config. Verify it took effect:
#   php artisan tinker --execute="var_dump(config('sanctum.stateful'));"
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# Local dev: null. Production with the SPA on a sibling subdomain, set the
# shared parent domain with a leading dot, e.g. SESSION_DOMAIN=.example.com
SESSION_DOMAIN=null
# Set true behind HTTPS so the session cookie is only sent over TLS.
# MUST be true whenever SESSION_SAME_SITE=none, or the browser drops the cookie.
SESSION_SECURE_COOKIE=false
# lax is enough when the SPA and API share a registrable domain (same-site);
# use none only for a truly cross-site SPA (then SECURE_COOKIE must be true).
SESSION_SAME_SITE=lax

# IMPORTANT: this is the FRONTEND (SPA) host, NOT the API host. Sanctum matches
# the request's Origin/Referer (always the SPA) against this list to decide
# whether to use the session cookie. Putting the API domain here = always 401
# after login. Bare host, no scheme. e.g. app.example.com
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# CORS — comma-separated SPA origins (WITH scheme) allowed to call the API with
# credentials. Must include the frontend origin, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base URL of the SPA frontend (WITH scheme). Used to build links emailed to
# users, such as the password-reset link. Single canonical origin.
FRONTEND_URL=http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local mail is caught by the MailHog container (see docker-compose.yml).
# Open the web inbox at http://localhost:8025. Use MAIL_MAILER=log to disable.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=bks-mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
