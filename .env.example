# Docker Container Prefix
CONTAINER_PREFIX=bks

# Application Configuration
APP_NAME=BekiApp
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=bks-mysql
DB_PORT=3306
DB_DATABASE=bks_db
DB_USERNAME=bks_user
DB_PASSWORD=bks_pass
# Root password for the MySQL container — keep distinct from DB_PASSWORD and
# change it before any non-local use.
DB_ROOT_PASSWORD=bks_root_pass

# Redis Configuration
REDIS_HOST=bks-redis
REDIS_PORT=6379

# Sanctum SPA Auth (cookie-based)
# !!! WARNING: the docker `app` (Laravel) service does NOT load this root .env —
# it reads backend/.env. Editing the auth vars below has NO effect on the API.
# To fix/login state, set SANCTUM_STATEFUL_DOMAINS / SESSION_* in backend/.env
# (see backend/.env.example for the full guide). The copies here are only a
# reminder; keep them in sync but treat backend/.env as the source of truth.
#
# Reminder of the two classic mistakes (full notes in backend/.env.example):
#   - SANCTUM_STATEFUL_DOMAINS must be the FRONTEND host, not the API host.
#   - SESSION_SAME_SITE=none requires SESSION_SECURE_COOKIE=true (+ HTTPS).
# In production set the SPA host + the shared parent domain, e.g.
#   SANCTUM_STATEFUL_DOMAINS=app.example.com  (FE host)
#   SESSION_DOMAIN=.example.com               (leading dot = shared by subdomains)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DRIVER=database
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax
# Set true behind HTTPS (production); REQUIRED if SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=false

# Node / Next.js Configuration
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production domains — SINGLE SOURCE OF TRUTH for docker-compose.prod.yml.
# nginx server_name is rendered from these; the frontend build derives its
# public URLs as https://${APP_DOMAIN} / https://${API_DOMAIN}. Set them on the
# server (this file is gitignored). Bare hostnames, no scheme, no trailing slash.
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
