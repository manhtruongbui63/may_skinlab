# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# App Configuration
NEXT_PUBLIC_APP_NAME="Laravel Next.js App (Docker)"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication
NEXT_PUBLIC_AUTH_STORAGE_KEY=auth_token

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Remote logging — ship client errors/logs to backend POST /api/logs.
# Auto-disabled in mock mode; set to "false" to turn off entirely.
NEXT_PUBLIC_ENABLE_REMOTE_LOG=true

# Other
NODE_ENV=development
