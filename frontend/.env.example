# Mock mode — dùng MockAuthRepository thay vì gọi API thật.
# Giữ mặc định "false". Chỉ bật "true" cho môi trường demo/dev không có backend;
# KHÔNG bật ở staging/production (sẽ phục vụ dữ liệu giả cho người dùng thật).
NEXT_PUBLIC_USE_MOCK=false

# API base URL (chỉ cần khi NEXT_PUBLIC_USE_MOCK=false)
NEXT_PUBLIC_API_URL=https://api.example.com

# Remote logging — gửi log/error của client lên backend POST /api/logs.
# Tự động tắt khi đang ở mock mode; đặt "false" để tắt hoàn toàn.
NEXT_PUBLIC_ENABLE_REMOTE_LOG=true
