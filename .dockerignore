# Build context = repo root (shared by docker/node and docker/php builds).
# Keep the context small and prevent host artifacts from leaking into images.

.git
.gitlab-ci.yml
**/.DS_Store

# Frontend host artifacts — must NOT clobber the clean install done in the
# builder stage.
frontend/node_modules
frontend/.next
frontend/.turbo

# Only .env.production should reach the frontend build (NEXT_PUBLIC_* are
# inlined). Exclude the dev/localhost env files so they can't leak in.
frontend/.env
frontend/.env.local
frontend/.env.docker
frontend/.env.development
frontend/.env.development.local

# Backend deps are installed in CI / not copied by the PHP image (volume-based).
backend/vendor
backend/node_modules
